generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  LGA_CHAIRMAN
  LGA_STAFF
  ADVERTISER
  ADMIN
}

enum LGAStatus {
  PENDING
  APPROVED
  SUSPENDED
  DEACTIVATED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── Citizen / General Users ──────────────────────────────────────────────────
model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime?
  phone               String?
  image               String?
  password            String?
  role                UserRole  @default(CITIZEN)
  state               String?
  lga                 String?
  isActive            Boolean   @default(true)
  isBanned            Boolean   @default(false)
  banReason           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// ─── NextAuth Tables ──────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── LGA Tables ───────────────────────────────────────────────────────────────
model LGA {
  id              String     @id @default(cuid())
  lgaName         String
  state           String
  chairmanName    String
  email           String     @unique
  phone           String
  officeAddress   String
  population      String?
  description     String?    @db.Text
  sectors         String[]
  logoUrl         String?
  status          LGAStatus  @default(PENDING)
  isVerified      Boolean    @default(false)
  freeUntil       DateTime?
  subscriptionEnd DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  chairman         LGAChairman?
  verificationDocs LGAVerificationDoc[]
  endowments       LGAEndowment[]
  inquiries        InvestorInquiry[]
  wards            Ward[]

  @@unique([lgaName, state])
  @@map("lgas")
}

model LGAChairman {
  id              String    @id @default(cuid())
  lgaId           String    @unique
  email           String    @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lga                 LGA                  @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  accounts            LGAAccount[]
  verificationTokens  LGAVerificationToken[]
  passwordResetTokens LGAPasswordResetToken[]

  @@map("lga_chairmen")
}

model LGAAccount {
  id                String  @id @default(cuid())
  chairmanId        String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("lga_accounts")
}

model LGAVerificationToken {
  id          String   @id @default(cuid())
  chairmanId  String
  token       String   @unique
  expires     DateTime
  createdAt   DateTime @default(now())

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@map("lga_verification_tokens")
}

model LGAPasswordResetToken {
  id          String   @id @default(cuid())
  chairmanId  String
  token       String   @unique
  expires     DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@map("lga_password_reset_tokens")
}

model LGAVerificationDoc {
  id          String             @id @default(cuid())
  lgaId       String
  docType     String
  fileUrl     String
  status      VerificationStatus @default(PENDING)
  uploadedAt  DateTime           @default(now())

  lga LGA @relation(fields: [lgaId], references: [id], onDelete: Cascade)

  @@map("lga_verification_docs")
}

// ─── Wards Feature ───────────────────────────────────────────────────────────

model Ward {
  id                String    @id @default(cuid())
  lgaId             String
  wardName          String
  wardNumber        Int?
  councillorName    String
  councillorEmail   String?
  councillorPhone   String?
  councillorImage   String?
  description       String?   @db.Text
  population        String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lga               LGA       @relation(fields: [lgaId], references: [id], onDelete: Cascade)

  @@unique([lgaId, wardName])
  @@map("wards")
}

// ─── Investment Feature ───────────────────────────────────────────────────────

enum ResourceCategory {
  AGRICULTURE
  MINERALS
  LIVESTOCK
  FISHERIES
  FORESTRY
  ENERGY
  TOURISM
  MANUFACTURING
}

enum InquiryStatus {
  PENDING
  REVIEWED
  CONNECTED
  CLOSED
}

model Investor {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  phone           String?
  company         String?
  country         String
  sectors         String[]
  minBudget       String?
  maxBudget       String?
  description     String?   @db.Text
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inquiries       InvestorInquiry[]

  @@map("investors")
}

model LGAEndowment {
  id              String           @id @default(cuid())
  lgaId           String
  category        ResourceCategory
  title           String
  description     String           @db.Text
  highlights      String[]
  investmentRange String?
  contactPerson   String?
  contactEmail    String?
  isPublished     Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  lga             LGA              @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  inquiries       InvestorInquiry[]

  @@map("lga_endowments")
}

model InvestorInquiry {
  id              String        @id @default(cuid())
  investorId      String
  lgaId           String
  endowmentId     String?
  message         String        @db.Text
  status          InquiryStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  investor        Investor      @relation(fields: [investorId], references: [id], onDelete: Cascade)
  lga             LGA           @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  endowment       LGAEndowment? @relation(fields: [endowmentId], references: [id], onDelete: SetNull)

  @@map("investor_inquiries")
}

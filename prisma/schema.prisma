generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  LGA_CHAIRMAN
  LGA_STAFF
  ADVERTISER
  ADMIN
}

enum LGAStatus {
  PENDING
  APPROVED
  SUSPENDED
  DEACTIVATED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── Citizen / General Users ──────────────────────────────────────────────────
model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime?
  phone               String?
  image               String?
  password            String?
  role                UserRole  @default(CITIZEN)
  state               String?
  lga                 String?
  isActive            Boolean   @default(true)
  isBanned            Boolean   @default(false)
  banReason           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  reactions           Reaction[]
  comments            Comment[]
  feedbacks           Feedback[]
  flags               FlagReport[]

  @@map("users")
}

// ─── NextAuth Tables ──────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

enum OTPPurpose {
  CITIZEN_LOGIN
  LGA_LOGIN
  REGISTER
  SENSITIVE
}

model OTPCode {
  id          String     @id @default(cuid())
  identifier  String
  code        String
  purpose     OTPPurpose
  attempts    Int        @default(0)
  lockedUntil DateTime?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  @@index([identifier, purpose])
  @@map("otp_codes")
}

// ─── LGA Tables ───────────────────────────────────────────────────────────────
model LGA {
  id                  String     @id @default(cuid())
  lgaName             String
  state               String
  chairmanName        String
  email               String     @unique
  phone               String
  officeAddress       String
  population          String?
  description         String?    @db.Text
  sectors             String[]
  logoUrl             String?
  status              LGAStatus  @default(PENDING)
  isVerified          Boolean    @default(false)
  freeUntil           DateTime?
  subscriptionEnd     DateTime?
  subscriptionStatus  String?
  tenureStartDate     DateTime?
  tenureEndDate       DateTime?
  tenureStatus        String     @default("ACTIVE")
  gracePeriodEndsAt   DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  chairman         LGAChairman?
  verificationDocs LGAVerificationDoc[]
  endowments       LGAEndowment[]
  inquiries        InvestorInquiry[]
  wards            Ward[]
  posts            Post[]
  staff            LGAStaff[]
  tenures          LGATenure[]
  projects         Project[]

  @@unique([lgaName, state])
  @@map("lgas")
}

model LGAChairman {
  id              String    @id @default(cuid())
  lgaId           String    @unique
  email           String    @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lga                 LGA                  @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  accounts            LGAAccount[]
  verificationTokens  LGAVerificationToken[]
  passwordResetTokens LGAPasswordResetToken[]
  staff               LGAStaff[]

  @@map("lga_chairmen")
}

model LGAAccount {
  id                String  @id @default(cuid())
  chairmanId        String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("lga_accounts")
}

model LGAVerificationToken {
  id          String   @id @default(cuid())
  chairmanId  String
  token       String   @unique
  expires     DateTime
  createdAt   DateTime @default(now())

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@map("lga_verification_tokens")
}

model LGAPasswordResetToken {
  id          String   @id @default(cuid())
  chairmanId  String
  token       String   @unique
  expires     DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  chairman LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@map("lga_password_reset_tokens")
}

model LGAVerificationDoc {
  id          String             @id @default(cuid())
  lgaId       String
  docType     String
  fileUrl     String
  status      VerificationStatus @default(PENDING)
  uploadedAt  DateTime           @default(now())

  lga LGA @relation(fields: [lgaId], references: [id], onDelete: Cascade)

  @@map("lga_verification_docs")
}

// ─── Wards Feature ───────────────────────────────────────────────────────────

model Ward {
  id                String    @id @default(cuid())
  lgaId             String
  wardName          String
  wardNumber        Int?
  councillorName    String
  councillorEmail   String?
  councillorPhone   String?
  councillorImage   String?
  description       String?   @db.Text
  population        String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lga               LGA       @relation(fields: [lgaId], references: [id], onDelete: Cascade)

  @@unique([lgaId, wardName])
  @@map("wards")
}

// ─── Engagement Feature (FR-01-03) ───────────────────────────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum FlagReason {
  INAPPROPRIATE
  MISINFORMATION
  SPAM
  OFFENSIVE
  OTHER
}

model Post {
  id        String     @id @default(cuid())
  lgaId     String
  title     String
  content   String     @db.Text
  imageUrl  String?
  status    PostStatus @default(PUBLISHED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lga       LGA          @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]
  feedbacks Feedback[]
  flags     FlagReport[]

  @@map("posts")
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("reactions")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Feedback {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  rating    Int
  category  String
  message   String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("feedbacks")
}

model FlagReport {
  id         String     @id @default(cuid())
  postId     String
  userId     String
  reason     FlagReason
  details    String?    @db.Text
  isReviewed Boolean    @default(false)
  createdAt  DateTime   @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("flag_reports")
}

// ─── Investment Feature ───────────────────────────────────────────────────────

enum ResourceCategory {
  AGRICULTURE
  MINERALS
  LIVESTOCK
  FISHERIES
  FORESTRY
  ENERGY
  TOURISM
  MANUFACTURING
}

enum InquiryStatus {
  PENDING
  REVIEWED
  CONNECTED
  CLOSED
}

model Investor {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  phone           String?
  company         String?
  country         String
  sectors         String[]
  minBudget       String?
  maxBudget       String?
  description     String?   @db.Text
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inquiries       InvestorInquiry[]

  @@map("investors")
}

model LGAEndowment {
  id              String           @id @default(cuid())
  lgaId           String
  category        ResourceCategory
  title           String
  description     String           @db.Text
  highlights      String[]
  investmentRange String?
  contactPerson   String?
  contactEmail    String?
  isPublished     Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  lga             LGA              @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  inquiries       InvestorInquiry[]

  @@map("lga_endowments")
}

model InvestorInquiry {
  id              String        @id @default(cuid())
  investorId      String
  lgaId           String
  endowmentId     String?
  message         String        @db.Text
  status          InquiryStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  investor        Investor      @relation(fields: [investorId], references: [id], onDelete: Cascade)
  lga             LGA           @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  endowment       LGAEndowment? @relation(fields: [endowmentId], references: [id], onDelete: SetNull)

  @@map("investor_inquiries")
}

// ─── Staff ────────────────────────────────────────────────────────────────────

model LGAStaff {
  id          String      @id @default(cuid())
  lgaId       String
  chairmanId  String
  name        String
  email       String      @unique
  phone       String?
  role        String      @default("STAFF")
  password    String?
  isActive    Boolean     @default(true)
  canPublish  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lga         LGA         @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  chairman    LGAChairman @relation(fields: [chairmanId], references: [id], onDelete: Cascade)

  @@map("lga_staff")
}

// ─── Tenure ───────────────────────────────────────────────────────────────────

model LGATenure {
  id             String    @id @default(cuid())
  lgaId          String
  chairmanName   String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean   @default(true)
  reElectionDoc  String?
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lga            LGA       @relation(fields: [lgaId], references: [id], onDelete: Cascade)

  @@map("lga_tenures")
}

// ─── Projects (FR-05/FR-06) ───────────────────────────────────────────────────

enum ProjectCategory {
  ROADS_INFRASTRUCTURE
  HEALTH
  EDUCATION
  WATER
  AGRICULTURE
  OTHER
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Project {
  id              String          @id @default(cuid())
  lgaId           String
  title           String
  description     String          @db.Text
  category        ProjectCategory @default(OTHER)
  status          ProjectStatus   @default(PENDING)
  latitude        Float?
  longitude       Float?
  budget          BigInt?
  startDate       DateTime?
  expectedEndDate DateTime?
  images          String[]
  videoUrl        String?
  isArchived      Boolean         @default(false)
  isPublished     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lga             LGA              @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  statusLogs      ProjectStatusLog[]

  @@map("projects")
}

model ProjectStatusLog {
  id         String   @id @default(cuid())
  projectId  String
  oldStatus  String
  newStatus  String
  changedBy  String
  note       String?
  createdAt  DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_status_logs")
}

// ─── Federal Allocation Tracking (FR-04) ─────────────────────────────────────

model AllocationRecord {
  id          String    @id @default(cuid())
  lgaName     String
  state       String
  month       Int
  year        Int
  amount      BigInt
  source      String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([lgaName, state, month, year])
  @@map("allocation_records")
}

model AllocationArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  month       Int?
  year        Int?
  coverImage  String?
  attachments String[]
  status      String    @default("DRAFT")
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("allocation_articles")
}

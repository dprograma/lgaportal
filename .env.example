# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lgaportal"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── Social login (Google) ──────────────────────────────────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Social login (LinkedIn) ────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps with the
# "Sign In with LinkedIn using OpenID Connect" product enabled.
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""

# ── Admin panel ─────────────────────────────────────────────────────────────
ADMIN_SECRET=""
ADMIN_PASSWORD=""
ADMIN_EMAIL=""

# ── File uploads (Cloudinary) ───────────────────────────────────────────────
# Create a free account at https://cloudinary.com and copy these from your
# dashboard. Used for project images/video and press release attachments —
# without these, the "Upload" buttons in the LGA dashboard return a clear
# "not configured" error instead of a working upload.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Payments (Paystack) ─────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=""

# ── LGA subscription pricing ────────────────────────────────────────────────
# Change these to update the renewal price shown/charged on the LGA dashboard
# Payments page — no code changes needed.
LGA_SUBSCRIPTION_FEE_NAIRA="30000"
LGA_SUBSCRIPTION_DURATION_DAYS="30"

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Optional in development — when unset, emails are logged instead of sent.
RESEND_API_KEY=""
RESEND_FROM=""
CONTACT_EMAIL=""

# ── Misc ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OPENAI_API_KEY=""
SEED_SECRET=""

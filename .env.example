# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/lgaportal"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── Social login (Google) ──────────────────────────────────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Social login (LinkedIn) ────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps with the
# "Sign In with LinkedIn using OpenID Connect" product enabled.
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""

# ── Admin panel ─────────────────────────────────────────────────────────────
ADMIN_SECRET=""
ADMIN_PASSWORD=""
ADMIN_EMAIL=""

# ── Payments (Paystack) ─────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=""

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Optional in development — when unset, emails are logged instead of sent.
RESEND_API_KEY=""
RESEND_FROM=""
CONTACT_EMAIL=""

# ── Misc ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OPENAI_API_KEY=""
SEED_SECRET=""
